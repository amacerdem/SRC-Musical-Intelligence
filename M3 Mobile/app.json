{
  "expo": {
    "name": "M3 Musical Mind",
    "slug": "m3-musical-mind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.src9.m3mind",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.src9.m3mind"
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      "expo-router"
    ]
  }
}
