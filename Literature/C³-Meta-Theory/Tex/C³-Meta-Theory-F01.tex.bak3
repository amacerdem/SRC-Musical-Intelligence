\midrule
Melodies decoded from EEG (maxCorr method) & \cohend{0.80} & 21 & $<$1.9e-08 \\
Individual trial-level decoding accuracy & significant & 21 & $<$0.05 \\
\bottomrule
\end{tabular}
\end{center}

\textbf{Falsification Criteria:}
\begin{itemize}[leftmargin=*, topsep=0pt, itemsep=0pt]
\item Random pitch sequences should not be decodable
\item Hearing-impaired individuals should show reduced decoding accuracy
\end{itemize}

