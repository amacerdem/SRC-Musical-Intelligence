\midrule
\multirow{3}{*}{Sample Size} & Small ($n < 20$) & 104 & 1.01 & \multirow{3}{*}{1088.53} & \multirow{3}{*}{$<$.001} \\
& Medium ($20 \leq n < 50$) & 144 & 1.06 & & \\
& Large ($n \geq 50$) & 140 & 1.86 & & \\
\midrule
\multirow{3}{*}{Modality} & fMRI & 186 & 1.52 & \multirow{3}{*}{22.4} & \multirow{3}{*}{$<$.001} \\
& EEG/MEG & 142 & 1.18 & & \\
& Behavioral & 146 & 0.89 & & \\
\midrule
